@model IEnumerable<Jumla.Models.Product>
@using Jumla.Models

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

<main>

    <!-- ── HERO ── -->
    <section class="hero-wrap">
        <!-- بعد -->
        <img src="~/images/site/hero.png" alt="Wholesale warehouse">   
        <div class="hero-content">
            <div class="hero-badge">
                <span class="material-symbols-outlined fill-icon" style="font-size:.85rem">verified</span>
                JORDAN'S WHOLESALE MARKETPLACE
            </div>
            <h1>Bulk Supplies,<br>Delivered with Precision.</h1>
            <p>Sourcing the finest local and international products for retailers across Jordan. Your business growth starts with our reliability.</p>
            <div class="hero-actions">
                <a asp-controller="User" asp-action="Products" class="btn-primary">
                    <span class="material-symbols-outlined" style="font-size:1rem">inventory_2</span>
                    Browse Catalog
                </a>
                <a asp-controller="Cart" asp-action="Index" class="btn-ghost">
                    <span class="material-symbols-outlined" style="font-size:1rem">bolt</span>
                    Quick Order
                </a>
            </div>
        </div>
    </section>

    <!-- ── CATEGORIES ── -->
    <section class="page-section">
        <h2 class="section-heading">Browse Departments</h2>
        <div class="cat-scroll">
            @if (ViewBag.Categories != null)
            {
                foreach (var category in ViewBag.Categories)
                {
                    <a asp-controller="User"
                       asp-action="Products"
                       asp-route-categoryId="@category.Id"
                       class="cat-item">
                        <div class="cat-circle">
                            <img src="@(category.ImageUrl ?? "")" alt="@category.Name"
                                 onerror="this.style.display='none';this.parentElement.innerHTML='<span class=\'material-symbols-outlined\' style=\'font-size:1.75rem\'>category</span>'">
                        </div>
                        <span class="cat-label">@category.Name</span>
                    </a>
                }
            }
            else
            {
                <p style="color:var(--muted);font-size:.85rem;">No categories found.</p>
            }
        </div>
    </section>

    <!-- ── PROMO BANNER ── -->
    @if (ViewBag.DiscountProducts != null)
    {
        foreach (var discountItem in ViewBag.DiscountProducts)
        {
            var discount = discountItem as Jumla.Models.Discount;
            if (discount != null)
            {
                <section class="page-section" style="padding-top:0;">
                    <div class="promo-banner">
                        <div class="promo-content">
                            <span class="promo-tag">B2B EXCLUSIVE</span>
                            <p class="promo-title">@discount.Percentage% Off — @discount.Title</p>
                            <p class="promo-sub">Valid @discount.StartDate.ToString("MMM dd") – @discount.EndDate.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </section>
                break;
            }
        }
    }

    <!-- ── FEATURED PRODUCTS ── -->
    <section class="page-section">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
            <h2 class="section-heading" style="margin-bottom:0;">Featured Wholesale</h2>
            <a asp-controller="User" asp-action="Products" class="section-link">View All</a>
        </div>

        <div class="row g-3">
            @if (Model != null && Model.Any())
            {
                @foreach (var product in Model)
                {
                    var firstImage = product.Images?.OrderBy(img => img.Id).FirstOrDefault()?.ImageUrl ?? "";
                    var stockClass = product.StockQuantity > 10 ? "stock-in" : product.StockQuantity > 0 ? "stock-low" : "stock-low";
                    var stockLabel = product.StockQuantity > 10 ? "IN STOCK" : product.StockQuantity > 0 ? "LOW STOCK" : "OUT OF STOCK";

                    <div class="col-6 col-lg-3">
                        <div class="product-card h-100">
                            <div class="product-img-wrap">
                                @if (!string.IsNullOrEmpty(firstImage))
                                {
                                    <img src="@firstImage" alt="@product.Name">
                                }
                                else
                                {
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                                        <span class="material-symbols-outlined" style="font-size:2.5rem;color:var(--muted);">image</span>
                                    </div>
                                }
                                <span class="stock-badge @stockClass">@stockLabel</span>
                            </div>

                            <p class="product-brand">@(product.Category?.Name?.ToUpper() ?? "GENERAL")</p>
                            <p class="product-name" title="@product.Name">@product.Name</p>
                            <p class="product-unit">Min. @product.MinOrderQuantity @product.Unit</p>

                            <div style="margin-top:auto;">
                                <div style="margin-bottom:.5rem;">
                                    <span class="product-price">JOD @product.WholesalePrice.ToString("0.00")</span>
                                    <span class="product-price-unit"> / unit</span>
                                </div>
                                <a asp-controller="User" asp-action="ProductDetails" asp-route-id="@product.Id" class="btn-add">
                                    <span class="material-symbols-outlined" style="font-size:1rem">add</span>
                                    Add to Cart
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <span class="material-symbols-outlined" style="font-size:3rem;color:var(--muted);">inventory_2</span>
                    <p style="color:var(--muted);margin-top:.75rem;">No products available at the moment.</p>
                </div>
            }
        </div>
    </section>

    <!-- ── WHY US ── -->
    <section class="why-section">
        <h2>Built for Jordan's Business Owners</h2>
        <div style="max-width:600px;margin:0 auto;">
            <div class="why-item">
                <div class="why-icon">
                    <span class="material-symbols-outlined">payments</span>
                </div>
                <div>
                    <p class="why-title">Transparent Bulk Pricing</p>
                    <p class="why-desc">Tiered wholesale prices that scale with your order size. No hidden fees, direct distributor rates.</p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon">
                    <span class="material-symbols-outlined">local_shipping</span>
                </div>
                <div>
                    <p class="why-title">Fast & Reliable Delivery</p>
                    <p class="why-desc">Covering Amman and surrounding governorates. Guaranteed on-time delivery for your restocking needs.</p>
                </div>
            </div>
            <div class="why-item" style="margin-bottom:0;">
                <div class="why-icon">
                    <span class="material-symbols-outlined">support_agent</span>
                </div>
                <div>
                    <p class="why-title">Dedicated Account Support</p>
                    <p class="why-desc">Our team is available to help you with orders, returns, and inventory planning whenever you need.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── TESTIMONIALS ── -->
    <section class="page-section">
        <h2 class="section-heading text-center" style="text-align:center;">Trusted by Local Retailers</h2>
        <div class="testimonial-scroll">
            @if (ViewBag.Testimonials != null && ((IEnumerable<dynamic>)ViewBag.Testimonials).Any())
            {
                foreach (var item in ViewBag.Testimonials)
                {
                    var testimonial = item as Jumla.Models.Testimonial;
                    if (testimonial != null)
                    {
                        var name = testimonial.User?.FullName ?? testimonial.User?.UserName ?? "Valued Client";
                        <div class="testimonial-card">
                            <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem;">
                                <div class="testimonial-avatar">
                                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(name)&background=107c41&color=fff" alt="@name">
                                </div>
                                <div>
                                    <p class="testimonial-name">@name</p>
                                    <p class="testimonial-role">Verified Buyer</p>
                                </div>
                            </div>
                            <p class="testimonial-text">"@testimonial.Content"</p>
                            <div class="stars">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <span class="material-symbols-outlined fill-icon" style="font-size:.9rem">star</span>
                                }
                            </div>
                        </div>
                    }
                }
            }
            else
            {
                <p style="color:var(--muted);font-size:.85rem;padding:.5rem 0;">No testimonials available yet.</p>
            }
        </div>
    </section>

    <!-- ── SUBMIT TESTIMONIAL ── -->
    <div class="submit-section">
        <h2>Share Your Experience</h2>
        <p>We'd love your feedback. Once approved by our team, it will appear on this page.</p>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <form asp-controller="User" asp-action="SubmitTestimonial" method="post" style="max-width:500px;margin:0 auto;">
                @Html.AntiForgeryToken()
                <textarea name="content"
                      class="submit-textarea"
                      rows="3"
                      placeholder="Share your experience with Jumla..."
                      required></textarea>
                <button type="submit" class="btn-primary" style="margin-top:.75rem;width:100%;justify-content:center;">
                    <span class="material-symbols-outlined" style="font-size:1rem">send</span>
                    Submit Testimonial
                </button>
            </form>
        }
        else
        {
            <p style="font-size:.85rem;color:var(--muted);margin-bottom:1rem;">You must be logged in to share your experience.</p>
            <a asp-controller="Account" asp-action="Login" class="btn-primary" style="justify-content:center;max-width:220px;margin:0 auto;">
                <span class="material-symbols-outlined" style="font-size:1rem">login</span>
                Login to Review
            </a>
        }
    </div>

    <!-- ── CTA ── -->
    <section class="cta-section">
        <h2>Start Your Wholesale Journey</h2>
        <p>Join hundreds of verified retailers across Jordan using Jumla for their daily inventory needs.</p>
        @if (User.Identity == null || !User.Identity.IsAuthenticated)
        {
            <a asp-controller="Account" asp-action="Register" class="btn-cta">Register Your Business Now</a>
        }
        else
        {
            <a asp-controller="User" asp-action="Products" class="btn-cta">Browse All Products</a>
        }
    </section>
    @section Styles {
        <link href="~/css/HomePage.css" rel="stylesheet">
    }

</main>
