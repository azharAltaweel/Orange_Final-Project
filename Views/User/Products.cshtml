@model IEnumerable<Product>
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}
@{
    ViewData["Title"] = "Products";
}
<link href="~/css/Products-User.css" rel="stylesheet" />

<div class="container py-5">

    <div class="row">

        <!-- SIDEBAR -->
        <div class="col-lg-3">

            <div class="filter-card">

                <h5 class="filter-title">
                    Categories
                </h5>
                <a asp-action="Products"
                   class="category-link @(ViewBag.SelectedCategory == null ? "active-category" : "")">

                    All Products

                </a>

                @foreach (var category in ViewBag.Categories)
                {
                    var isActive = ViewBag.SelectedCategory == category.Id;

                    <a asp-action="Products"
                       asp-route-categoryId="@category.Id"
                       class="category-link @(isActive ? "active-category" : "")">

                        @category.Name

                    </a>
                }

            </div>

        </div> 


        <!-- PRODUCTS AREA -->
        <div class="col-lg-9">

            <!-- SEARCH + SORT -->
            <form method="get" class="products-toolbar mb-4">

                <div class="toolbar-search">

                    <i class="fa-solid fa-magnifying-glass"></i>

                    <input type="text"
                           name="search"
                           placeholder="Search skincare products..." />

                    <button type="submit">
                        Search
                    </button>

                </div>

                <div class="toolbar-sort">

                    <label>Sort by</label>

                    <select name="sortOrder"
                            onchange="this.form.submit()">

                        <option value="featured">Featured</option>
                        <option value="name">Name A-Z</option>
                        <option value="price">Price: Low to High</option>
                        <option value="newest">Newest</option>

                    </select>

                </div>

            </form>

            </div>

            <!-- Products Grid -->
            <div class="row g-4">

                @foreach (var product in Model)
                {
                    
    decimal finalPrice = product.Price;

    if (product.Discount != null)
    {
        finalPrice = product.Price -
        (product.Price * product.Discount.Percentage / 100);
    }

                    <div class="col-md-4">

                        <div class="card border-0 shadow-sm h-100 product-card">
                        <div class="position-relative">

                            <img src="@product.Images.FirstOrDefault()?.ImageUrl"
                                 class="card-img-top product-image" />

                            @if (product.Discount != null)
                            {
                                <span class="discount-badge">
                                    -@product.Discount.Percentage%
                                </span>
                            }

                            <button class="wishlist-btn position-absolute top-0 end-0 m-3"
                                    data-product-id="@product.Id"
                                    data-product-name="@product.Name"
                                    data-product-price="@product.Price"
                                    data-product-image="@product.Images.FirstOrDefault()?.ImageUrl">

                                <i class="bi bi-heart"></i>

                            </button>

                        </div>

                            <div class="card-body">

                                <p class="text-muted small">
                                    @product.Category.Name
                                </p>

                                <h5 class="fw-bold">
                                    @product.Name
                                </h5>
                            <div class="price-wrapper mt-3">

                                @if (product.Discount != null)
                                {
                                    <div class="d-flex align-items-center gap-2">

                                        <h6 class="discount-price mb-0">
                                            $@finalPrice.ToString("0.00")
                                        </h6>

                                        <span class="original-price">
                                            $@product.Price
                                        </span>

                                    </div>
                                }
                                else
                                {
                                    <h6 class="fw-bold mb-0">
                                        $@product.Price
                                    </h6>
                                }

                            </div>

                            <a asp-controller="User" asp-action="ProductDetails"
                                   asp-route-id="@product.Id"
                                   class="btn btn-dark w-100 rounded-pill mt-3">

                                    View Details

                                </a>

                            </div>

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

</div>
<script src="~/js/Products-User.js"></script>