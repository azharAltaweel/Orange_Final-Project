@model IEnumerable<Jumla.Models.Category>
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "Categories";
    var categories = Model?.ToList() ?? new List<Jumla.Models.Category>();
}
 <link href="~/css/CategoryUser.css" rel="stylesheet" />  

<main class="container py-5" style="max-width:1140px;">

    <!-- ── Hero ── -->
    <section class="mb-5">
        <h1 class="section-title mb-3">All Categories</h1>
    </section>

    <!-- ── Grid ── -->
    @if (categories.Any())
    {
        <div class="categories-grid">
            @foreach (var cat in categories)
            {
                <div class="cat-card">

                    <!-- Image -->
                    <div class="cat-img-wrap">
                        <img src="@(string.IsNullOrEmpty(cat.ImageUrl) ? "/images/categories/default-placeholder.png" : cat.ImageUrl)"
                             alt="@cat.Name"
                             loading="lazy" />
                    </div>

                    <!-- Body -->
                    <div class="cat-body">
                        <span class="cat-label">Department</span>
                        <h2 class="cat-name">@cat.Name</h2>
                        @if (cat.Products != null)
                        {
                            <p class="cat-count">@cat.Products.Count products</p>
                        }

                        <a asp-controller="User"
                           asp-action="Products"
                           asp-route-categoryId="@cat.Id"
                           class="cat-btn">
                            View Category
                        </a>
                    </div>

                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-cats">
            <i class="fa-regular fa-folder-open"></i>
            <p>No categories available yet.</p>
        </div>
    }

</main>
