@model IEnumerable<E_commerce_Website__Skincare_.Models.Category>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    var categories = Model?.ToArray() ?? new E_commerce_Website__Skincare_.Models.Category[0];
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&amp;family=Jost:wght@300;400;500&amp;display=swap" rel="stylesheet">
<link href="~/css/CategoryUser.css" rel="stylesheet">

<main class="container py-5" style="max-width:1140px;">

    <!-- ── Hero ── -->
    <section class="mb-5 pb-2">
        <h1 class="section-title mb-3">Curated Rituals</h1>
        <p class="section-sub">Discover our intentionally designed skincare categories, each crafted to nourish your skin and elevate your daily self-care journey.</p>
    </section>

    @for (int i = 0; i < categories.Length; i += 2)
    {
        bool isEvenRowGroup = (i / 2) % 2 == 0;

        if (isEvenRowGroup)
        {
            <!-- ── TYPE A ROW GROUP: Large (Left) + Small (Right) ── -->
            <div class="row grid-gap mb-0" style="margin-bottom: 1.1rem !important;">

                <!-- First Category in pair (Large Card) -->
                @{
                    var catLeft = categories[i];
                }
                <div class="col-12 col-md-8 mb-0">
                    <a asp-controller="Product" asp-action="Category" asp-route-id="@catLeft.Id" class="text-decoration-none text-dark">
                        <div class="card-glow">
                            <div class="img-wrap" style="position:relative;">
                                <img src="@(string.IsNullOrEmpty(catLeft.ImageUrl) ? "https://placeholder.co/800x400" : catLeft.ImageUrl)" alt="@catLeft.Name">
                                <div class="overlay"></div>
                                <div class="card-caption">
                                    <span class="label-caps text-white d-block mb-1" style="opacity:.85;">Collection</span>
                                    <h2>@catLeft.Name</h2>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Second Category in pair (Small Card) -->
                @if (i + 1 < categories.Length)
                {
                    var catRight = categories[i + 1];
                    <div class="col-12 col-md-4 mb-0">
                        <a asp-controller="Product" asp-action="Category" asp-route-id="@catRight.Id" class="text-decoration-none text-dark">
                            <div class="card-glow h-100">
                                <div class="img-wrap">
                                    <img src="@(string.IsNullOrEmpty(catRight.ImageUrl) ? "https://placeholder.co/400x400" : catRight.ImageUrl)" alt="@catRight.Name">
                                </div>
                                <div class="card-body-text">
                                    <h2>@catRight.Name</h2>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- ── TYPE B ROW GROUP: Small (Left) + Large Split (Right) ── -->
            <div class="row grid-gap mb-0" style="margin-bottom: 1.1rem !important;">

                <!-- First Category in pair (Small Card) -->
                @{
                    var catLeft = categories[i];
                }
                <div class="col-12 col-md-4">
                    <a asp-controller="Product" asp-action="Category" asp-route-id="@catLeft.Id" class="text-decoration-none text-dark">
                        <div class="card-glow">
                            <div class="img-wrap" style="position:relative;">
                                <img src="@(string.IsNullOrEmpty(catLeft.ImageUrl) ? "https://placeholder.co/400x400" : catLeft.ImageUrl)" alt="@catLeft.Name">
                                <div class="overlay"></div>
                                <div class="card-caption"><h2>@catLeft.Name</h2></div>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Second Category in pair (Large Split Card) -->
                @if (i + 1 < categories.Length)
                {
                    var catRight = categories[i + 1];
                    <div class="col-12 col-md-8">
                        <a asp-controller="Product" asp-action="Category" asp-route-id="@catRight.Id" class="text-decoration-none text-dark">
                            <div class="card-glow">
                                <div class="row g-0 h-100">
                                    <div class="col-12 col-sm-5 split-text order-2 order-sm-1 d-flex flex-column justify-content-center">
                                        <span class="label-caps">Daily Essentials</span>
                                        <h2>@catRight.Name</h2>
                                        <div class="line-anim mt-2"></div>
                                    </div>
                                    <div class="col-12 col-sm-7 order-1 order-sm-2">
                                        <div class="img-wrap" style="height:100%; min-height:240px;">
                                            <img src="@(string.IsNullOrEmpty(catRight.ImageUrl) ? "https://placeholder.co/800x400" : catRight.ImageUrl)" alt="@catRight.Name">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    }
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>