@model E_commerce_Website__Skincare_.Models.Order

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = $"Order #{Model.Id}";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet">

<style>
    :root {
        --bg: #fdf9f4;
        --surface-low: #f7f3ee;
        --surface-card: #ffffff;
        --surface-high2: #e6e2dd;
        --on-surface: #1c1b19;
        --on-variant: #49473d;
        --outline: #7a776c;
        --outline-var: #cbc6b9;
        --primary: #635f40;
        --success: #3a6b45;
        --success-bg: #e8f5ec;
        --shadow: 0 4px 20px -4px rgba(80,64,48,.08);
        --sec-cont: #f8d8db;
        --on-sec-cont: #755d5f;
    }

    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        font-size: 1.25rem;
        vertical-align: middle;
        line-height: 1;
    }

    main {
        padding: 3.5rem 0 5rem;
        background: var(--bg);
        font-family: 'Inter', sans-serif;
        color: var(--on-surface);
    }

    .breadcrumb-gc {
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--on-variant);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: 2rem;
    }

        .breadcrumb-gc a {
            color: var(--on-variant);
            text-decoration: none;
        }

            .breadcrumb-gc a:hover {
                color: var(--primary);
            }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-weight: 600;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        color: var(--on-surface);
        letter-spacing: -.02em;
        margin-bottom: .4rem;
    }

    .order-id {
        font-size: .78rem;
        color: var(--on-variant);
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    /* البادج الخاص بحالة الطلب */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1rem;
        border-radius: 9999px;
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .status-Completed {
        background: var(--success-bg);
        color: var(--success);
    }

    .status-Processing {
        background: #fef3cd;
        color: #7a5c00;
    }

    .status-Cancelled {
        background: #fde8e8;
        color: #ba1a1a;
    }

    .gc-card {
        background: var(--surface-card);
        border-radius: 14px;
        box-shadow: var(--shadow);
        padding: 1.75rem;
        margin-bottom: 1.25rem;
    }

    .gc-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--on-surface);
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--outline-var);
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    /* Tracking الخط الزمني */
    .tracking-steps {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        position: relative;
        padding: .5rem 0;
    }

    .tracking-line {
        position: absolute;
        top: 20px;
        left: 10%;
        right: 10%;
        height: 2px;
        background: var(--outline-var);
        z-index: 0;
    }

    .tracking-line-fill {
        position: absolute;
        top: 20px;
        left: 10%;
        height: 2px;
        background: var(--primary);
        z-index: 1;
    }

    .tracking-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .6rem;
        z-index: 2;
        flex: 1;
    }

    .step-dot {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid var(--outline-var);
        background: var(--surface-card);
    }

        .step-dot.done {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

    .step-label {
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--on-variant);
        text-align: center;
    }

        .step-label.done-text {
            color: var(--primary);
        }

    /* Table التنسيق */
    .order-table-header {
        display: grid;
        grid-template-columns: 1fr 100px 80px 100px;
        padding: .6rem 1rem;
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--on-variant);
        border-bottom: 1px solid var(--outline-var);
        margin-bottom: .75rem;
    }

    .order-item-row {
        display: grid;
        grid-template-columns: 1fr 100px 80px 100px;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid rgba(203,198,185,.35);
        gap: 1rem;
        border-radius: 10px;
    }

    .order-item-img {
        width: 68px;
        height: 86px;
        border-radius: 8px;
        overflow: hidden;
        background: var(--surface-low);
    }

        .order-item-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .item-name {
        font-size: .95rem;
        font-weight: 600;
        color: var(--on-surface);
        margin-bottom: .2rem;
    }

    .item-variant {
        font-size: .78rem;
        color: var(--on-variant);
    }

    .item-qty, .item-price {
        font-size: .9rem;
        color: var(--on-surface);
        text-align: center;
    }

    .item-total {
        font-size: .95rem;
        font-weight: 600;
        color: var(--primary);
        text-align: right;
    }

    .info-label {
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--on-variant);
        margin-bottom: .4rem;
    }

    .info-value {
        font-size: .9rem;
        color: var(--on-surface);
        line-height: 1.6;
    }

    .info-divider {
        border: none;
        border-top: 1px solid var(--outline-var);
        margin: 1.25rem 0;
    }

    /* Summary */
    .order-summary {
        background: var(--surface-low);
        border-radius: 14px;
        box-shadow: var(--shadow);
        padding: 1.75rem;
        position: sticky;
        top: 88px;
    }

    .summary-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--on-surface);
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--outline-var);
        margin-bottom: 1.25rem;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .85rem;
        font-size: .88rem;
        color: var(--on-variant);
    }

        .summary-row span:last-child {
            font-weight: 600;
            color: var(--on-surface);
        }

    .summary-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.1rem;
        border-top: 1px solid var(--outline-var);
        margin-top: .5rem;
        margin-bottom: 1.5rem;
    }

    .total-value {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 500;
        color: var(--primary);
    }

    .btn-gc-outline {
        background: transparent;
        color: var(--primary);
        border: 1px solid var(--primary);
        border-radius: 12px;
        padding: .85rem 1.5rem;
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .15em;
        text-transform: uppercase;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        text-decoration: none;
        width: 100%;
        justify-content: center;
    }

    /* media (max-width: 767px) {
        .order-table-header {
            display: none;
        }

        .order-item-row {
            grid-template-columns: 1fr 1fr;
        }
    } */
</style>

<main>
    <div class="container-xl px-4 px-md-5">

        <!-- Breadcrumb -->
        <div class="breadcrumb-gc">
            <a asp-action="Profile" asp-controller="User">Home</a><span>/</span>
            <a asp-action="Profile" asp-controller="User">My Profile</a><span>/</span>
            <span style="color:var(--on-surface)">Order #@Model.Id</span>
        </div>

        <!-- Title Row -->
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-5">
            <div>
                <h1 class="page-title mb-1">Order Details</h1>
                <p class="order-id mb-2">Order ID: #@Model.Id  ·  Placed on @Model.OrderDate.ToString("MMMM dd, yyyy")</p>
                <span class="status-badge status-@Model.Status">
                    <span class="material-symbols-outlined" style="font-size:.9rem;font-variation-settings:'FILL' 1,'wght' 400">check_circle</span>
                    @Model.Status
                </span>
            </div>
            <a href="#" class="btn-gc-outline" style="width:auto;margin:0">
                <span class="material-symbols-outlined" style="font-size:1rem">receipt_long</span>
                Download Invoice
            </a>
        </div>

        <div class="row g-4 g-xl-5">

            <!-- ── LEFT COLUMN ── -->
            <div class="col-12 col-lg-8">

                <!-- ORDER TRACKING -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">local_shipping</span>
                        Order Tracking
                    </div>
                    <div class="tracking-steps">
                        <div class="tracking-line"></div>
                        <div class="tracking-line-fill" style="width: @(Model.Status == "Processing" ? "40%" : Model.Status == "Completed" ? "100%" : "0%")"></div>

                        <div class="tracking-step">
                            <div class="step-dot done">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                            </div>
                            <span class="step-label done-text">Confirmed</span>
                            <span class="step-date">May 12</span>
                        </div>
                        <div class="tracking-step">
                            <div class="step-dot @(Model.Status == "Processing" || Model.Status == "Completed" ? "done" : "")">
                                <span class="material-symbols-outlined">data_exploration</span>
                            </div>
                            <span class="step-label">Processing</span>
                        </div>
                        <div class="tracking-step">
                            <div class="step-dot @(Model.Status == "Completed" ? "done" : "")">
                                <span class="material-symbols-outlined">home</span>
                            </div>
                            <span class="step-label">Completed</span>
                        </div>
                        <div class="tracking-step">
                            <div class="step-dot done">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                    </div>
                            <span class="step-label done-text">Delivered</span>
                            <span class="step-date">May 16</span>
                </div>
                    </div>
                </div>

                <!-- ORDER ITEMS -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">inventory_2</span>
                        Items Ordered
                    </div>

                    <!-- Table Header (desktop) -->
                    <div class="order-table-header">
                        <span>Product</span>
                        <span class="text-center">Price</span>
                        <span class="text-center">Qty</span>
                        <span class="text-end">Total</span>
                    </div>

                    @if (Model.OrderItems != null)
                    {
                        @foreach (var item in Model.OrderItems)
                        {
                            <div class="order-item-row">
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="order-item-img">
                                        @if (item.Product?.Images != null && item.Product.Images.Any())
                                        {
                                            <img src="@item.Product.Images.FirstOrDefault()?.ImageUrl" class="card-img-top product-image" />
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                                <span class="material-symbols-outlined text-muted">image</span>
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        <p class="item-name">@item.Product.Name</p>
                                        <p class="item-variant">Premium Glow Care</p>
                                    </div>
                                </div>
                                <div class="item-price">$@item.Price</div>
                                <div class="item-qty">× @item.Quantity</div>
                                <div class="item-total">$@(item.Price* item.Quantity)</div>
                            </div>
                        }
                    }
                </div>

                </div><!-- /items card -->
                <!-- SHIPPING & PAYMENT INFO -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">info</span>
                        Order Information
                    </div>

                    <div class="row g-4">
                        <!-- Shipping Address -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Shipping Address</p>
                            <p class="info-value">Amman, Jordan</p>
                        </div>

                        <div class="col-12"><hr class="info-divider"></div>

                        <!-- Payment Method -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Status Details</p>
                            <p class="info-value">Your order status is currently: <strong>@Model.Status</strong></p>
                        </div>
                        <!-- Shipping Method -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Shipping Method</p>
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined" style="color:var(--primary)">local_shipping</span>
                                <p class="info-value mb-0">
                                    Standard Delivery — Free<br>
                                    <span style="font-size:.78rem;color:var(--on-variant)">Estimated 3–5 business days</span>
                                </p>
                    </div>
                </div>

                        <div class="col-12"><hr class="info-divider"></div>

                        <!-- Tracking Number -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Tracking Number</p>
                            <div class="d-flex align-items-center gap-2">
                                <p class="info-value mb-0" style="font-family:monospace;letter-spacing:.05em">JO-482910-GC</p>
                                <button style="background:none;border:none;color:var(--primary);cursor:pointer;padding:0" title="Copy">
                                    <span class="material-symbols-outlined" style="font-size:1rem">content_copy</span>
                                </button>
                            </div>
                        </div>
                        <!-- Order Date -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Order Date</p>
                            <p class="info-value mb-0">Sunday, May 12, 2024 · 10:47 AM</p>
                        </div>
                    </div>
            </div>

            </div><!-- /col-lg-8 -->
            <!-- ── RIGHT COLUMN ── -->
            <div class="col-12 col-lg-4">

                <!-- Order Summary -->
                <div class="order-summary">
                    <h3 class="summary-title">Order Summary</h3>

                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span>$@Model.TotalAmount</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span>FREE</span>
                    </div>
                    <div class="summary-row">
                        <span>Discount</span>
                        <span style="color:var(--success)">— $0.00</span>
                    </div>
                    <div class="summary-row">
                        <span>Tax (Estimated)</span>
                        <span>$12.40</span>
                    </div>

                    <div class="summary-total">
                        <span class="total-label">Total Paid</span>
                        <span class="total-value">$@Model.TotalAmount</span>
                    </div>

                    <a asp-action="Profile" asp-controller="Account" class="btn-gc-outline">
                        <span class="material-symbols-outlined" style="font-size:1rem">arrow_back</span>
                        Back to Profile
                    </a>
                </div>
            </div>

        </div>
    </div>

            </div><!-- /col-lg-4 -->

        </div><!-- /row -->
    </div><!-- /container -->
</main>