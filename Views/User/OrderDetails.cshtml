@model Jumla.Models.Order

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = $"Order #{Model.Id}";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet">

<style>
 
</style>

<main>
    <div class="container-xl px-4 px-md-5">

        <!-- Breadcrumb -->
        <div class="breadcrumb-gc">
            <a asp-action="Profile" asp-controller="User">Home</a><span>/</span>
            <a asp-action="Profile" asp-controller="User">My Profile</a><span>/</span>
            <span style="color:var(--on-surface)">Order #@Model.Id</span>
        </div>

        <!-- Title Row -->
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-5">
            <div>
                <h1 class="page-title mb-1">Order Details</h1>
                <p class="order-id mb-2">Order ID: #@Model.Id  ·  Placed on @Model.OrderDate.ToString("MMMM dd, yyyy")</p>
                <span class="status-badge status-@Model.Status.ToString()">
                    <span class="material-symbols-outlined" style="font-size:.9rem;font-variation-settings:'FILL' 1,'wght' 400">check_circle</span>
                    @Model.Status.ToString()
                </span>
            </div>
            <a href="#" class="btn-gc-outline" style="width:auto;margin:0">
                <span class="material-symbols-outlined" style="font-size:1rem">receipt_long</span>
                Download Invoice
            </a>
        </div>

        <div class="row g-4 g-xl-5">

            <!-- ── LEFT COLUMN ── -->
            <div class="col-12 col-lg-8">

                <!-- ORDER TRACKING -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">local_shipping</span>
                        Order Tracking
                    </div>
                    <div class="tracking-steps">
                        <div class="tracking-line"></div>
                        <div class="tracking-line-fill" style="width: @(Model.Status == OrderStatus.Processing ? "50%" : "0%")"></div>

                        <div class="tracking-step">
                            <div class="step-dot done">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                            </div>
                            <span class="step-label done-text">Confirmed</span>
                            <span class="step-date">May 12</span>
                        </div>

                        <div class="tracking-step">
                            <div class="step-dot @(Model.Status == OrderStatus.Processing || Model.Status == OrderStatus.Completed ? "done" : "")">
                                <span class="material-symbols-outlined">data_exploration</span>
                            </div>
                            <span class="step-label">Processing</span>
                        </div>

                        <div class="tracking-step">
                            <div class="step-dot @(Model.Status == OrderStatus.Completed ? "done" : "")">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                            </div>
                            <span class="step-label">Delivered</span>
                            <span class="step-date">May 16</span>
                        </div>
                    </div>
                </div>
                <!-- ORDER ITEMS -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">inventory_2</span>
                        Items Ordered
                    </div>

                    <!-- Table Header (desktop) -->
                    <div class="order-table-header">
                        <span>Product</span>
                        <span class="text-center">Price</span>
                        <span class="text-center">Qty</span>
                        <span class="text-end">Total</span>
                    </div>

                    @if (Model.OrderItems != null)
                    {
                        @foreach (var item in Model.OrderItems)
                        {
                            <div class="order-item-row">
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="order-item-img">
                                        @if (item.Product?.Images != null && item.Product.Images.Any())
                                        {
                                            <img src="@item.Product.Images.FirstOrDefault()?.ImageUrl" class="card-img-top product-image" />
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                                <span class="material-symbols-outlined text-muted">image</span>
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        <p class="item-name">@item.Product.Name</p>
                                        <p class="item-variant">@(item.Product?.Unit ?? "")</p>
                                    </div>
                                </div>
                                <div class="item-price">$@item.Price</div>
                                <div class="item-qty">× @item.Quantity</div>
                                <div class="item-total">$@(item.Price* item.Quantity)</div>
                            </div>
                        }
                    }
                </div>

                </div><!-- /items card -->
                <!-- SHIPPING & PAYMENT INFO -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">info</span>
                        Order Information
                    </div>

                    <div class="row g-4">
                        <!-- Shipping Address -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Shipping Address</p>
                            <p class="info-value">Amman, Jordan</p>
                        </div>

                        <div class="col-12"><hr class="info-divider"></div>

                        <!-- Payment Method -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Status Details</p>
                        <p class="info-value">Your order status is currently: <strong>@Model.Status.ToString()</strong></p>

                    </div>
                        <!-- Shipping Method -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Shipping Method</p>
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined" style="color:var(--primary)">local_shipping</span>
                                <p class="info-value mb-0">
                                    Standard Delivery — Free<br>
                                    <span style="font-size:.78rem;color:var(--on-variant)">Estimated 3–5 business days</span>
                                </p>
                    </div>
                </div>

                        <div class="col-12"><hr class="info-divider"></div>

                        <!-- Tracking Number -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Tracking Number</p>
                            <div class="d-flex align-items-center gap-2">
                                <p class="info-value mb-0" style="font-family:monospace;letter-spacing:.05em">JO-482910-GC</p>
                                <button style="background:none;border:none;color:var(--primary);cursor:pointer;padding:0" title="Copy">
                                    <span class="material-symbols-outlined" style="font-size:1rem">content_copy</span>
                                </button>
                            </div>
                        </div>
                        <!-- Order Date -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Order Date</p>
                            <p class="info-value mb-0">Sunday, May 12, 2024 · 10:47 AM</p>
                        </div>
                    </div>
            </div>

            </div><!-- /col-lg-8 -->
            <!-- ── RIGHT COLUMN ── -->
            <div class="col-12 col-lg-4">

                <!-- Order Summary -->
                <div class="order-summary">
                    <h3 class="summary-title">Order Summary</h3>

                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span>$@Model.TotalAmount</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span>FREE</span>
                    </div>
                    <div class="summary-row">
                        <span>Discount</span>
                        <span style="color:var(--success)">— $0.00</span>
                    </div>
                    <div class="summary-row">
                        <span>Tax (Estimated)</span>
                        <span>$12.40</span>
                    </div>

                    <div class="summary-total">
                        <span class="total-label">Total Paid</span>
                        <span class="total-value">$@Model.TotalAmount</span>
                    </div>

                    <a asp-action="Profile" asp-controller="Account" class="btn-gc-outline">
                        <span class="material-symbols-outlined" style="font-size:1rem">arrow_back</span>
                        Back to Profile
                    </a>
                </div>
            </div>

        </div>
    </div>

            </div><!-- /col-lg-4 -->

        </div><!-- /row -->
    </div><!-- /container -->
</main>