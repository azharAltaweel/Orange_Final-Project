<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - GlowCare</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;600&display=swap"
          rel="stylesheet">

    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom CSS -->
    <link href="~/css/UserLayout.css"
          rel="stylesheet"
          asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-custom sticky-top py-3">
        <div class="container">

            <!-- Logo -->
            <a class="brand"
               asp-controller="Home"
               asp-action="Index">
                GLOWCARE
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent"
                    aria-controls="navbarContent"
                    aria-expanded="false"
                    aria-label="Toggle navigation">

                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navbar Content -->
            <div class="collapse navbar-collapse"
                 id="navbarContent">

                <!-- Nav Links -->
                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="User"
                           asp-action="Products">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="#">
                            Categories
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="User"
                           asp-action="Products">
                            Products
                        </a>
                    </li>

                </ul>

                <!-- Search Form -->
                <form asp-controller="User"
                      asp-action="Products"
                      method="get"
                      class="d-flex me-3 search-form">

                    <input class="form-control search-box"
                           type="search"
                           name="search"
                           placeholder="Search products or categories..."
                           value="@Context.Request.Query["search"]" />

                </form>

                <!-- Right Icons -->
                <div class="d-flex align-items-center gap-3 nav-icons">

                    <!-- Wishlist -->
                    <a asp-controller="User"
                       asp-action="Wishlist"
                       class="wishlist-nav position-relative">

                        <i class="bi bi-heart fs-5"></i>

                        <span id="wishlist-badge"
                              class="wishlist-badge d-none">
                            0
                        </span>
                    </a>

                    <!-- Cart -->
                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="cart-link position-relative text-dark text-decoration-none">

                        <span class="material-symbols-outlined">
                            shopping_bag
                        </span>

                        <span class="cart-badge"
                              style="display:none;">
                            0
                        </span>
                    </a>

                    <!-- Profile -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account"
                           asp-action="Profile"
                           class="profile-icon text-dark text-decoration-none"
                           title="My Profile">

                            <span class="material-symbols-outlined">
                                person
                            </span>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="Login"
                           class="profile-icon text-dark text-decoration-none"
                           title="Login / Sign Up">

                            <span class="material-symbols-outlined">
                                person
                            </span>
                        </a>
                    }

                </div>

            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container py-5">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="mt-5 py-5 bg-light">
        <div class="container">

            <div class="row">

                <!-- Brand -->
                <div class="col-md-4 mb-4">
                    <h3 class="brand">GLOWCARE</h3>

                    <p>
                        Curating intentional skincare rituals
                        for the modern individual.
                    </p>
                </div>

                <!-- Shop -->
                <div class="col-md-2">
                    <h5 class="footer-title">
                        Shop
                    </h5>

                    <a href="#"
                       class="footer-link d-block">
                        Shop All
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Serums
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Cleansers
                    </a>
                </div>

                <!-- About -->
                <div class="col-md-2">
                    <h5 class="footer-title">
                        About
                    </h5>

                    <a href="#"
                       class="footer-link d-block">
                        Our Story
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Blog
                    </a>
                </div>

                <!-- Support -->
                <div class="col-md-2">
                    <h5 class="footer-title">
                        Support
                    </h5>

                    <a href="#"
                       class="footer-link d-block">
                        Contact
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Privacy Policy
                    </a>
                </div>

            </div>

            <hr />

            <div class="text-center">
                © 2026 GlowCare. All Rights Reserved.
            </div>

        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>