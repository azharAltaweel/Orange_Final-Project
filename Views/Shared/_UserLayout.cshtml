@using Microsoft.AspNetCore.Identity
@using Jumla.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Jumla</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;600&display=swap"
          rel="stylesheet">

    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom CSS -->
    <link href="~/css/UserLayout.css"
          rel="stylesheet"
          asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-custom sticky-top py-3">
        <div class="container">

            <a class="brand" asp-controller="User" asp-action="HomePage">
                JUMLA
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent"
                    aria-controls="navbarContent"
                    aria-expanded="false"
                    aria-label="Toggle navigation">

                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navbar Content -->
            <div class="collapse navbar-collapse"
                 id="navbarContent">

                <!-- Nav Links -->
                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="User"
                           asp-action="HomePage">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="User"
                           asp-action="Categories">
                            Categories
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="User"
                           asp-action="Products">
                            Products
                        </a>
                    </li>

                </ul>

                <!-- Search Form -->
                <form asp-controller="User"
                      asp-action="Products"
                      method="get"
                      class="d-flex me-3 search-form">

                    <input class="form-control search-box"
                           type="search"
                           name="search"
                           placeholder="Search products or categories..."
                           value="@Context.Request.Query["search"]" />

                </form>

                <div class="d-flex gap-3 nav-icons align-items-center">
                    <a asp-controller="User" asp-action="Wishlist">
                        <span class="material-symbols-outlined cursor-pointer">favorite</span>
                    </a>
                    <a asp-controller="Cart" asp-action="Index" class="cart-link d-flex align-items-center">
                        <span class="material-symbols-outlined cursor-pointer">shopping_bag</span>
                        <span class="cart-badge" style="display: none;">0</span>
                    </a>
                    
                    <!-- Profile Dropdown -->
                    <div class="dropdown d-inline-block">
                        <a href="#" class="text-decoration-none text-dark d-flex align-items-center" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="material-symbols-outlined cursor-pointer m-0">person</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="profileDropdown" style="min-width: 215px; z-index: 1050;">
                            @if (SignInManager.IsSignedIn(User))
                            {
                                var currentUser = await UserManager.GetUserAsync(User);
                                var displayName = currentUser?.FullName ?? User.Identity?.Name?.Split('@')[0] ?? "User";
                                
                                <li class="px-3 py-2 border-bottom mb-2">
                                    <span class="d-block fw-bold text-dark" style="font-size: 13px;">Hello, @displayName!</span>
                                    <span class="d-block text-muted" style="font-size: 11px; cursor: default;">@User.Identity?.Name</span>
                                </li>
                                
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item fw-medium" asp-controller="Admin" asp-action="Dashboard" style="color: #006130;">
                                            <span class="material-symbols-outlined">dashboard</span> Admin Panel
                                        </a>
                                    </li>
                                }
                                
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <span class="material-symbols-outlined">person</span> My Profile
                                    </a>
                                </li>
                                
                                <li><hr class="dropdown-divider opacity-5 my-2"></li>
                                
                                <li class="px-2">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger rounded-3 w-100 border-0 bg-transparent text-start">
                                            <span class="material-symbols-outlined">logout</span> Sign Out
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Login">
                                        <span class="material-symbols-outlined">login</span> Login
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Register">
                                        <span class="material-symbols-outlined">person_add</span> Register
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main >
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="mt-5 py-5 bg-light">
        <div class="container">

            <div class="row">

                <!-- Brand -->
                <div class="col-md-4 mb-4">
                    <h3 class="brand">JUMLA</h3>

                    <p>Jordan's trusted wholesale marketplace for retailers and businesses.</p>
                </div>

                <!-- Shop -->
                <div class="col-md-2">
                    <h5 class="footer-title">
                        Shop
                    </h5>

                    <a href="#"
                       class="footer-link d-block">
                        Shop All
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Food
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Cleaners
                    </a>
                </div>

                <!-- About -->
                <div class="col-md-2">
                    <h5 class="footer-title">
                        About
                    </h5>

                    <a href="#"
                       class="footer-link d-block">
                        Our Story
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Blog
                    </a>
                </div>

                <!-- Support -->
                <div class="col-md-2">
                    <h5 class="footer-title">
                        Support
                    </h5>

                    <a href="#"
                       class="footer-link d-block">
                        Contact
                    </a>

                    <a href="#"
                       class="footer-link d-block">
                        Privacy Policy
                    </a>
                </div>

            </div>

            <hr />

            <div class="text-center">
                © 2026 Jumla. All Rights Reserved.
            </div>

        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SweetAlert2 & jumla Custom Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/jumla-alerts.js" asp-append-version="true"></script>
    
    @if (TempData["Success"] != null || TempData["SuccessMessage"] != null || TempData["Error"] != null || TempData["ErrorMessage"] != null)
    {
        <script>
            // Scripts are at bottom of <body> — DOM is already ready, no DOMContentLoaded needed
            (function() {
                var successMsg = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((string)(TempData["Success"] ?? TempData["SuccessMessage"] ?? "")))';
                var errorMsg = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((string)(TempData["Error"] ?? TempData["ErrorMessage"] ?? "")))';
                if (successMsg) {
                    JumlaAlert.success('Success!', successMsg);
                } else if (errorMsg) {
                    JumlaAlert.error('Oops...', errorMsg);
                }
            })();
        </script>
    }

    @RenderSection("Scripts", required: false)

</body>
</html>