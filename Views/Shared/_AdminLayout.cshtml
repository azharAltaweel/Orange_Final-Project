<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jumla Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


    <!-- Google Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

          <!-- Dashboard CSS -->
    <link href="~/css/dashboard.css" rel="stylesheet" />
</head>

<body>

    <!-- ═════════════ SIDEBAR ═════════════ -->
    <aside class="sidebar">

        <div class="sidebar-brand">
            <h1>Jumla Admin</h1>
        </div>

        <nav class="sidebar-nav">

            <a asp-controller="Admin" asp-action="Dashboard"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fa-solid fa-chart-pie nav-icon"></i> Dashboard
            </a>

            <a asp-controller="Admin" asp-action="OrdersInfo"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "OrdersInfo" ? "active" : "")">
                <i class="fa-solid fa-cart-shopping nav-icon"></i> Orders
                @if (ViewData["NumOfNewOrders"] != null)
                {
                    <span class="nav-badge">@ViewData["NumOfNewOrders"]</span>
                }
            </a>

            <a asp-controller="Admin" asp-action="UsersInfo"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "UsersInfo" ? "active" : "")">
                <i class="fa-solid fa-users nav-icon"></i> Users
            </a>

            <a asp-controller="Admin" asp-action="Categories"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "CategoriesInfo" ? "active" : "")">
                <i class="fa-solid fa-tags nav-icon"></i> Categories
            </a>

            <a asp-controller="Admin" asp-action="ProductsInfo"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "ProductsInfo" ? "active" : "")">
                <i class="fa-solid fa-box nav-icon"></i> Products
            </a>

            <a asp-controller="Admin" asp-action="Testimonials"
               class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Testimonials" ? "active" : "")">
                <i class="fa-solid fa-star nav-icon"></i> Reviews
                @if (ViewData["NumOfNotificationsToApproveOrRejectIt"] != null)
                {
                    <span class="nav-badge">@ViewData["NumOfNotificationsToApproveOrRejectIt"]</span>
                }
            </a>

        </nav>

        <div class="sidebar-bottom">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-item w-100 border-0 bg-transparent text-start">
                    <i class="fa-solid fa-arrow-right-from-bracket nav-icon"></i> Logout
                </button>
            </form>
        </div>

    </aside>

    <!-- ═════════════ MAIN WRAPPER ═════════════ -->
    <div class="main-wrap">

        <!-- ═════════════ TOPBAR ═════════════ -->
        <header class="topbar">
            <span class="topbar-title">
                Hello, @(ViewData["AdminName"] ?? "Admin")
            </span>

            <div class="topbar-search">
            </div>

            <div class="topbar-user" onclick="openProfile()" title="Edit Profile">
                <div class="topbar-user-info">
                    <div class="name"> @(ViewData["AdminName"] ?? "Admin")</div>
                    <div class="role">Administrator</div>
                </div>
                <div class="avatar">
                    @(((string)ViewData["AdminName"])?.Substring(0, 1).ToUpper() ?? "A")
                </div>
            </div>

        </header>

        <!-- ═════════════ PAGE CONTENT ═════════════ -->
        <main class="content">

            @RenderBody()

        </main>

        <!-- ═══ FOOTER ═══ -->
        <footer class="footer">

            <div class="footer-grid">

                <div class="footer-brand">

                    <h2>Jumla Wholesale</h2>

                    <p>
                        Empowering businesses and retailers with
                        quality wholesale products, seamless ordering,
                        and efficient inventory management.
                    </p>

                    <p style="margin-top:12px;font-size:12px;">
                        © 2026 Jumla Wholesale.
                        All rights reserved.
                    </p>

                </div>

                <div class="footer-col">

                    <h4>Portal Support</h4>

                    <a href="#">Internal Wiki</a>
                    <a href="#">Technical Support</a>
                    <a href="#">API Documentation</a>

                </div>

                <div class="footer-col">

                    <h4>System Status</h4>
                    <p style="font-size:13px;margin-bottom:10px;">
                        <span class="status-dot"></span>All systems operational
                    </p>
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>

                </div>

            </div>

        </footer>
    </div>

  

    @* <!-- ═══ PROFILE MODAL ═══ -->
    <div class="modal fade" id="profileModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-semibold">My Profile</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="profileModalBody">
                    <div class="text-center py-4">
                        <div class="spinner-border" style="color:var(--olive);" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div> *@

    <!-- SweetAlert2 & Jumla Custom Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/jumla-alerts.js" asp-append-version="true"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/admin-profile.js"></script>
@await RenderSectionAsync("Scripts", required: false)


</body>
</html>