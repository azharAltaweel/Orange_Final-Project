<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_commerce_Website__Skincare_</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_commerce_Website__Skincare_.styles.css" asp-append-version="true" />
    <link href="~/css/dashboard.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">

</head>
<body>

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <h1>GlowCare Admin</h1>
        </div>

        <nav class="sidebar-nav">
            <a href="#" class="nav-item active">
                <i class="fa-solid fa-grid-2 nav-icon"></i> Dashboard
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-cart-shopping nav-icon"></i> Orders
                @* Numbers Of New Orders *@
                <span class="nav-badge">@ViewData["NumOfNewOrders"]</span>
            </a>
            <a asp-controller="Admin" asp-action="UsersInfo" class="nav-item">
                <i class="fa-solid fa-users nav-icon"></i> Users
            </a>

            <a asp-controller="Admin" asp-action="Categories" class="nav-item">
                <i class="fa-solid fa-tags nav-icon"></i> Categories
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-tags nav-icon"></i> Products
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-star nav-icon"></i> Reviews / Testimonials
                @* Number Of Notifications To Approve Or Reject It *@
                <span class="nav-badge">@ViewData["NumOfNotificationsToApproveOrRejectIt"]</span>
            </a>
        </nav>

        <div class="sidebar-bottom">
            <a href="#" class="nav-item">
                <i class="fa-solid fa-arrow-right-from-bracket nav-icon"></i> Logout
            </a>
        </div>
    </aside>

    <!-- ═══ MAIN WRAP ═══ -->
    <div class="main-wrap">

        <!-- TOPBAR -->
        <header class="topbar">
            <span class="topbar-title">Hello Admin</span>

            <div class="topbar-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Search data..." />
            </div>

            <div class="topbar-user">
                <div class="topbar-user-info">
                    <div class="name">Salwa Ali</div>
                </div>
                <div class="avatar">@ViewData["ProfilePic"]</div>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="content">
            @RenderBody()
        </main>


        <!-- ═══ FOOTER ═══ -->
        <footer class="footer">
            <div class="footer-grid">
                <div class="footer-brand">
                    <h2>GlowCare Rituals</h2>
                    <p>Empowering administrators to manage the world's most curated skincare rituals with precision and elegance.</p>
                    <p style="margin-top:12px;font-size:12px;">© 2024 GlowCare Rituals. All rights reserved.</p>
                </div>
                <div class="footer-col">
                    <h4>Portal Support</h4>
                    <a href="#">Internal Wiki</a>
                    <a href="#">Technical Support</a>
                    <a href="#">API Documentation</a>
                </div>
                <div class="footer-col">
                    <h4>System Status</h4>
                    <p style="font-size:13px;margin-bottom:10px;"><span class="status-dot"></span>All systems operational</p>
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                </div>
            </div>
        </footer>

    </div>

</body>
</html>
