@using Microsoft.AspNetCore.Identity
@using E_commerce_Website__Skincare_.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_commerce_Website__Skincare_.styles.css" asp-append-version="true" />
    
    <style>
        .brand-text {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            color: #635f40;
            letter-spacing: 1px;
        }
        .cursor-pointer { cursor: pointer; }
        .cart-link { position: relative; color: inherit; text-decoration: none; }
        .cart-badge {
            position: absolute;
            top: -5px;
            right: -8px;
            background: #635f40;
            color: white;
            font-size: 10px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        /* Icons */
        .nav-icons span {
            cursor: pointer;
            color: #444;
            transition: 0.3s;
        }

        .nav-icons span:hover {
            color: #635f40;
        }

        /* Premium Dropdown Styles */
        .dropdown-menu {
            border: none !important;
            border-radius: 14px !important;
            box-shadow: 0 10px 30px rgba(99, 95, 64, 0.12) !important;
            padding: 10px !important;
            border: 1px solid rgba(99, 95, 64, 0.08) !important;
            background-color: #ffffff !important;
        }

        .dropdown-item {
            border-radius: 8px !important;
            color: #444 !important;
            transition: all 0.25s ease !important;
            font-size: 14px !important;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px !important;
        }

        .dropdown-item:hover {
            background-color: #fdf9f4 !important;
            color: #635f40 !important;
        }

        .dropdown-item.text-danger:hover {
            background-color: #fff5f5 !important;
            color: #dc3545 !important;
        }

        .dropdown-item span {
            font-size: 19px !important;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm fixed-top py-3">
            <div class="container">
                <a class="navbar-brand brand-text fs-3" asp-area="" asp-controller="Home" asp-action="Index">GLOWCARE</a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="material-symbols-outlined">menu</span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item px-2">
                            <a class="nav-link text-dark fw-medium" asp-area="" asp-controller="Home" asp-action="Index">Shop All</a>
                        </li>
                        <li class="nav-item px-2">
                            <a class="nav-link text-dark fw-medium" href="#">Serums</a>
                        </li>
                        <li class="nav-item px-2">
                            <a class="nav-link text-dark fw-medium" href="#">Cleansers</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3 nav-icons">
                        <span class="material-symbols-outlined cursor-pointer">search</span>
                        <span class="material-symbols-outlined cursor-pointer">favorite</span>
                        <a asp-controller="Cart" asp-action="Index" class="cart-link d-flex align-items-center">
                            <span class="material-symbols-outlined cursor-pointer">shopping_bag</span>
                            <span class="cart-badge" style="display: none;">0</span>
                        </a>
                        
                        <!-- Profile Dropdown -->
                        <div class="dropdown d-inline-block">
                            <a href="#" class="text-decoration-none text-dark d-flex align-items-center" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="material-symbols-outlined cursor-pointer m-0">person</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="profileDropdown" style="min-width: 215px; z-index: 1050;">
                                @if (SignInManager.IsSignedIn(User))
                                {
                                    var currentUser = await UserManager.GetUserAsync(User);
                                    var displayName = currentUser?.FullName ?? User.Identity?.Name?.Split('@')[0] ?? "User";
                                    
                                    <li class="px-3 py-2 border-bottom mb-2">
                                        <span class="d-block fw-bold text-dark" style="font-size: 13px;">Hello, @displayName!</span>
                                        <span class="d-block text-muted" style="font-size: 11px; cursor: default;">@User.Identity?.Name</span>
                                    </li>
                                    
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item fw-medium" asp-controller="Admin" asp-action="Dashboard" style="color: #635f40;">
                                                <span class="material-symbols-outlined">dashboard</span> Admin Panel
                                            </a>
                                        </li>
                                    }
                                    
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <span class="material-symbols-outlined">person</span> My Profile
                                        </a>
                                    </li>
                                    
                                    <li><hr class="dropdown-divider opacity-5 my-2"></li>
                                    
                                    <li class="px-2">
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger rounded-3 w-100 border-0 bg-transparent text-start">
                                                <span class="material-symbols-outlined">logout</span> Sign Out
                                            </button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Login">
                                            <span class="material-symbols-outlined">login</span> Login
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Register">
                                            <span class="material-symbols-outlined">person_add</span> Register
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - E_commerce_Website__Skincare_ - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- SweetAlert2 & GlowCare Custom Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/glowcare-alerts.js" asp-append-version="true"></script>
    
    @if (TempData["Success"] != null || TempData["SuccessMessage"] != null || TempData["Error"] != null || TempData["ErrorMessage"] != null)
    {
        <script>
            // Scripts are at bottom of <body> — DOM is already ready, no DOMContentLoaded needed
            (function() {
                var successMsg = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((string)(TempData["Success"] ?? TempData["SuccessMessage"] ?? "")))';
                var errorMsg = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((string)(TempData["Error"] ?? TempData["ErrorMessage"] ?? "")))';
                if (successMsg) {
                    GlowAlert.success('Success!', successMsg);
                } else if (errorMsg) {
                    GlowAlert.error('Oops...', errorMsg);
                }
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
