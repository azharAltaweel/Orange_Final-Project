@using Microsoft.AspNetCore.Identity
@using E_commerce_Website__Skincare_.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    @if (User.IsInRole("Admin"))
    {
        <li class="nav-item">
            <a class="nav-link fw-bold d-flex align-items-center gap-1" asp-area="" asp-controller="Admin" asp-action="Dashboard" title="Admin Dashboard" style="color: #635f40;">
                <span class="material-symbols-outlined align-middle">dashboard</span> Admin Panel
            </a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Account" asp-action="Profile" title="My Profile">
            <span class="material-symbols-outlined align-middle">account_circle</span> 
            Hello, @(User.Identity?.Name?.Split('@')[0] ?? "User")!
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
    </li>
}
</ul>

