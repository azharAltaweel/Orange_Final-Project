@model IEnumerable<E_commerce_Website__Skincare_.Models.Category>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="~/css/categoryAdminPage.css" rel="stylesheet" />

<main class="content">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h2 style="font-weight: 600;">Categories</h2>
            <p style="color: #666;">Manage your product categories — add, edit, or remove them.</p>
        </div>
        <button class="btn" style="background-color: #7a8a5f; color: white; border-radius: 8px; padding: 10px 20px;" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i> Add Category
        </button>
    </div>

    <!-- TOOLBAR (Matches image_3aaeb5.png) -->
    <div class="toolbar-card" style="background: white; padding: 15px; border-radius: 12px; margin-bottom: 20px; display: flex; align-items: center; gap: 15px; border: 1px solid #eee;">
        <div class="search-box" style="flex-grow: 1; position: relative;">
            <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 15px; top: 12px; color: #999;"></i>
            <input type="text" id="searchInput" onkeyup="filterTable('searchInput', 'catTableBody', 2)" placeholder="Search categories..." style="width: 100%; padding: 10px 10px 10px 40px; border-radius: 8px; border: 1px solid #ddd; background: #f9f9f7;">
        </div>

        <span class="count-badge" style="background: #f0f0eb; padding: 5px 15px; border-radius: 20px; color: #666;">@Model.Count() categories</span>

    </div>

    <!-- TABLE VIEW -->
    <div class="table-container" style="background: white; border-radius: 12px; border: 1px solid #eee; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead style="background: #f9f9f7; border-bottom: 1px solid #eee;">
                <tr>
                    <th style="padding: 15px;">ID</th>
                    <th>IMAGE</th>
                    <th>NAME</th>
                    <th>IMAGE URL</th>
                    <th>PRODUCTS</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 15px; color: #666;">#@item.Id</td>
                        <td>
                            <img src="@item.ImageUrl" style="width: 60px; height: 60px; border-radius: 12px; object-fit: cover; background: #e0e0d5;" />
                        </td>
                        <td>
                            <div style="font-weight: 600; color: #333;">@item.Name</div>
                            <div style="font-size: 12px; color: #999;">StringLength: @item.Name.Length/100</div>
                        </td>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="color: #999; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@item.ImageUrl</span>
                                <button class="btn-copy" style="border: 1px solid #ddd; background: white; padding: 4px 8px; border-radius: 6px; font-size: 12px;">
                                    <i class="fa-regular fa-copy"></i> Copy
                                </button>
                            </div>
                        </td>
                        @* <td>
                            <span style="background: #d4e7d4; color: #4a6d4a; padding: 6px 12px; border-radius: 20px; font-size: 13px; display: inline-flex; align-items: center; gap: 5px;">
                                <i class="fa-solid fa-box-archive"></i> @item.ProductCount products
                            </span>
                        </td> *@
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <button class="btn-edit" style="border: 1px solid #ddd; background: white; padding: 6px 12px; border-radius: 6px;"><i class="fa-regular fa-pen-to-square"></i> Edit</button>
                                <button class="btn-delete" style="border: 1px solid #ddd; background: white; padding: 6px 10px; border-radius: 6px;"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</main>

<!-- Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; padding: 10px;">
            <div class="modal-header border-0">
                <div>
                    <h5 class="modal-title" id="modalTitle" style="font-weight: 600;">Add New Category</h5>
                    <p class="text-muted small mb-0" id="modalSubtitle">Fill in the details to create a new category.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="categoryForm" asp-controller="Admin" asp-action="UpsertCategory" method="post">
                    <!-- Hidden ID field for Editing -->
                    <input type="hidden" id="fieldId" name="Id" value="0" />

                    <div class="mb-3" id="idDisplayGroup" style="display:none;">
                        <label class="form-label">Category ID</label>
                        <input type="text" class="form-control bg-light" id="displayId" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" name="Name" id="fieldName" class="form-control" placeholder="e.g. Serums & Essences" maxlength="100" required oninput="document.getElementById('charCount').innerText = this.value.length">
                        <div class="text-end text-muted" style="font-size: 12px;"><span id="charCount">0</span>/100</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Image URL <span class="text-danger">*</span></label>
                        <div class="preview-box border rounded text-center p-4 mb-2" style="background: #f9f9f7; border-style: dashed !important;">
                            <img id="imgPreview" src="#" alt="Preview" style="display:none; max-height: 150px; width: 100%; object-fit: cover; border-radius: 10px;" />
                            <div id="previewPlaceholder">
                                <i class="fa-solid fa-image text-muted d-block mb-2" style="font-size: 24px;"></i>
                                <span class="text-muted small">Paste an image URL below to preview</span>
                            </div>
                        </div>
                        <input type="url" name="ImageUrl" id="fieldUrl" class="form-control bg-light" placeholder="https://example.com/image.jpg" required onchange="updatePreview(this.value)">
                        <p class="text-muted mt-1" style="font-size: 11px;">Paste a direct image URL. Supports .jpg, .png, .webp</p>
                    </div>

                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" id="submitBtn" class="btn btn-success px-4" style="background-color: #7a8a5f; border: none;">
                            <i class="fa-solid fa-check me-1"></i> Save Category
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>