@using E_commerce_Website__Skincare_.Models
@model ApplicationUser

<div class="p-1">

    <!-- Avatar Section -->
    <div class="text-center mb-4">
        <div class="mx-auto mb-3"
             style="width:72px;height:72px;border-radius:50%;background:var(--olive);
                    color:#fff;display:flex;align-items:center;justify-content:center;
                    font-size:26px;font-weight:600;">
            @(Model.FullName?.Substring(0, 1).ToUpper() ?? "A")
        </div>
        <h6 class="fw-semibold mb-0">@Model.FullName</h6>
        <p style="font-size:12px;color:var(--muted);">Administrator</p>
    </div>

    <!-- Form -->
    <div class="mb-3">
        <label style="font-size:12px;font-weight:500;color:var(--muted);">Full Name</label>
        <input type="text"
               id="profileFullName"
               class="form-control"
               value="@Model.FullName" />
    </div>

    <div class="mb-3">
        <label style="font-size:12px;font-weight:500;color:var(--muted);">Email Address</label>
        <input type="email"
               id="profileEmail"
               class="form-control"
               value="@Model.Email" />
    </div>

    <div class="mb-3">
        <label style="font-size:12px;font-weight:500;color:var(--muted);">
            New Password
            <span style="color:var(--muted);font-weight:400;">(leave blank to keep current)</span>
        </label>
        <div class="input-group">
            <input type="password"
                   id="profileNewPassword"
                   class="form-control"
                   placeholder="••••••••" />
            <button class="btn btn-secondary btn-sm"
                    type="button"
                    onclick="togglePassword('profileNewPassword', this)">
                <i class="fa-regular fa-eye"></i>
            </button>
        </div>
    </div>

    <div id="profileAlert" class="alert d-none" role="alert"></div>

    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary w-100" onclick="saveProfile()">
            <i class="fa-solid fa-floppy-disk me-1"></i> Save Changes
        </button>
        <button class="btn btn-secondary" data-bs-dismiss="modal">
            Cancel
        </button>
    </div>

</div>
