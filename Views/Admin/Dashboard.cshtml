@model IEnumerable<E_commerce_Website__Skincare_.Models.Category>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h2>Dashboard Overview</h2>
        <p>Welcome back. Here's what's happening today.</p>
    </div>
</div>


<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Total Products</div>
        <div class="stat-value">@ViewBag.TotalProducts</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total Orders</div>
        <div class="stat-value">@ViewBag.TotalOrders</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Users</div>
        <div class="stat-value">@(ViewBag.TotalUsers -1)</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Categories</div>
        <div class="stat-value">@ViewBag.TotalCategories</div>
    </div>
</div>

<div style="display: flex; gap: 20px; margin-top: 20px;">

    <!-- Weekly Orders Chart -->
    <div class="card" style="flex: 1; min-width: 300px;">
        <div class="card-header"><h3>Weekly Orders</h3></div>
        <div class="mini-chart">
            <div class="chart-bars">
                @if (ViewBag.WeeklyOrders != null)
                {
                    @foreach (var day in ViewBag.WeeklyOrders)
                    {
                        <div class="bar-wrap">
                            @* Using a simple multiplier for height since we don't have the Percentage property *@
                            <div class="bar" style="height:@(day.Count * 10)px;" title="@day.Count Orders"></div>
                            <span class="bar-label">@day.DayLabel</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Weekly New Users Chart -->
    @* <div class="card" style="flex: 1; min-width: 300px;">
        <div class="card-header"><h3>Weekly New Users</h3></div>
        <div class="mini-chart">
            <div class="chart-bars">
                @if (ViewBag.WeeklyNewUsers != null)
                {
                    @foreach (var day in ViewBag.WeeklyNewUsers)
                    {
                        <div class="bar-wrap">
                            <div class="bar highlight" style="height:@(day.Count * 10)px;" title="@day.Count Users"></div>
                            <span class="bar-label">@day.DayLabel</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div> *@
</div>