@using Microsoft.AspNetCore.Identity
@using Jumla.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@using Jumla.Models.ViewModels;
@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - JUMLA</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

<!-- Navbar -->
<nav class="navbar fixed-top shadow-sm py-3 bg-white">
    <div class="container d-flex justify-content-between align-items-center">
        <a class="brand text-decoration-none" asp-controller="Home" asp-action="Index" style="font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 600; color: #006130;">JUMLA</a>

        <div class="d-none d-md-flex gap-4">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Shop All</a>
            <a href="#" class="text-decoration-none text-muted">category1</a>
            <a href="#" class="text-decoration-none text-muted">category2</a>
        </div>

        <div class="d-flex gap-3 align-items-center">
            <span class="material-symbols-outlined">search</span>
            <span class="material-symbols-outlined">favorite</span>
            <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-dark d-flex align-items-center">
                <span class="material-symbols-outlined">shopping_bag</span>
            </a>
            
            <!-- Profile Dropdown -->
            <div class="dropdown d-inline-block">
                <a href="#" class="text-decoration-none text-dark d-flex align-items-center" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="material-symbols-outlined m-0 text-primary">person</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="profileDropdown" style="min-width: 215px; z-index: 1050;">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        var displayName = currentUser?.FullName ?? User.Identity?.Name?.Split('@')[0] ?? "User";
                        
                        <li class="px-3 py-2 border-bottom mb-2">
                            <span class="d-block fw-bold text-dark" style="font-size: 13px;">Hello, @displayName!</span>
                            <span class="d-block text-muted" style="font-size: 11px; cursor: default;">@User.Identity?.Name</span>
                        </li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li>
                                <a class="dropdown-item fw-medium" asp-controller="Admin" asp-action="Dashboard" style="color: #006130;">
                                    <span class="material-symbols-outlined">dashboard</span> Admin Panel
                                </a>
                            </li>
                        }
                        
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                <span class="material-symbols-outlined">person</span> My Profile
                            </a>
                        </li>
                        
                        <li><hr class="dropdown-divider opacity-5 my-2"></li>
                        
                        <li class="px-2">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger rounded-3 w-100 border-0 bg-transparent text-start">
                                    <span class="material-symbols-outlined">logout</span> Sign Out
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Login">
                                <span class="material-symbols-outlined">login</span> Login
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Register">
                                <span class="material-symbols-outlined">person_add</span> Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</nav>

<!-- Main -->
<div class="container" style="padding-top:120px; padding-bottom: 60px;">
    <div class="auth-container row g-0">

        <!-- Left -->
        <div class="col-md-6 d-none d-md-block hero-side">
            <div class="hero-overlay"></div>
            <div class="hero-text">
                    <h3>Quality products at wholesale prices.</h3>
                    <p>Join our wholesale community.</p>
            </div>
        </div>

        <!-- Right -->
        <div class="col-md-6 p-4 p-md-5">

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-4">
                <li class="nav-item">
                    <a asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="nav-link">Login</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active">Sign Up</a>
                </li>
            </ul>


            <!-- Form -->
            <form asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="BusinessName" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Business Name</label>
                        <input asp-for="BusinessName" class="form-control" placeholder="e.g. Al-Taweel Market" required>
                        <span asp-validation-for="BusinessName" class="text-danger small"></span>
                    </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="John Doe" required>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" required>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="+962" required>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" required>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3">Create Account</button>
            </form>

            <p class="text-center mt-4 text-muted">
                Already have an account?
                <a asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="fw-bold text-decoration-none" style="color: #006130;">Log in</a>
            </p>

        </div>
    </div>
</div>

<!-- Footer -->
<footer class="mt-5 py-5">
    <div class="container">
        <div class="row g-4">

            <div class="col-md-3">
                <h5 class="brand">JUMLA</h5>
                    <p class="text-muted small">Your trusted destination for quality products at wholesale prices.</p>
            </div>

            <div class="col-md-3">
                <h6 class="fw-bold small text-uppercase mb-3" style="letter-spacing: 1px; color: #006130;">Shop</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-muted small">Shop All</a></li>
                    <li><a href="#" class="text-decoration-none text-muted small">Best Sellers</a></li>
                </ul>
            </div>

            <div class="col-md-3">
                <h6 class="fw-bold small text-uppercase mb-3" style="letter-spacing: 1px; color: #006130;">Resources</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-muted small">Privacy Policy</a></li>
                    <li><a href="#" class="text-decoration-none text-muted small">Terms of Service</a></li>
                </ul>
            </div>

            <div class="col-md-3">
                <h6 class="fw-bold small text-uppercase mb-3" style="letter-spacing: 1px; color: #006130;">Company</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-muted small">Contact Us</a></li>
                    <li><a href="#" class="text-decoration-none text-muted small">Careers</a></li>
                </ul>
            </div>

        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- SweetAlert2 & jumla Custom Alerts -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/jumla-alerts.js" asp-append-version="true"></script>

@if (TempData["Success"] != null || TempData["SuccessMessage"] != null || TempData["Error"] != null || TempData["ErrorMessage"] != null)
{
    <script>
        (function() {
            var successMsg = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((string)(TempData["Success"] ?? TempData["SuccessMessage"] ?? "")))';
            var errorMsg = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((string)(TempData["Error"] ?? TempData["ErrorMessage"] ?? "")))';
            if (successMsg) {
                JumlaAlert.success('Success!', successMsg);
            } else if (errorMsg) {
                JumlaAlert.error('Oops...', errorMsg);
            }
        })();
    </script>
}
</body>
</html>
