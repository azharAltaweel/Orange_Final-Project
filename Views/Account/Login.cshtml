@using E_commerce_Website__Skincare_.Models.ViewModels;
@model LoginViewModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - GLOWCARE</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>

<body>

<!-- Navbar -->
<nav class="navbar fixed-top shadow-sm">
    <div class="container d-flex justify-content-between align-items-center">
        <div class="brand">GLOWCARE</div>

        <div class="d-none d-md-flex gap-4">
            <a href="#" class="text-decoration-none text-muted">Shop All</a>
            <a href="#" class="text-decoration-none text-muted">Serums</a>
            <a href="#" class="text-decoration-none text-muted">Cleansers</a>
            <a href="#" class="text-decoration-none text-muted">Rituals</a>
        </div>

        <div class="d-flex gap-3">
            <span class="material-symbols-outlined">search</span>
            <span class="material-symbols-outlined">favorite</span>
            <span class="material-symbols-outlined">shopping_bag</span>
            <span class="material-symbols-outlined text-primary">person</span>
        </div>
    </div>
</nav>

<!-- Main -->
<div class="container" style="padding-top:120px; padding-bottom: 60px;">
    <div class="auth-container row g-0">

        <!-- Left -->
        <div class="col-md-6 d-none d-md-block hero-side">
            <div class="hero-overlay"></div>
            <div class="hero-text">
                <h3>Elevate your daily ritual.</h3>
                <p>Join our skincare community.</p>
            </div>
        </div>

        <!-- Right -->
        <div class="col-md-6 p-4 p-md-5">

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-4">
                <li class="nav-item">
                    <a class="nav-link active">Login</a>
                </li>
                <li class="nav-item">
                    <a asp-action="Register" class="nav-link">Sign Up</a>
                </li>
            </ul>






            <!-- Form -->
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" required>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-label small fw-semibold text-uppercase" style="letter-spacing: 1px;">Password</label>
                        <a href="#" class="small text-decoration-none" style="color: #635f40;">Forgot?</a>
                    </div>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" asp-for="RememberMe" />
                    <label class="form-check-label text-muted small" asp-for="RememberMe">
                        Remember me for 30 days
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3">Sign In</button>
            </form>

            <p class="text-center mt-4 text-muted">
                Don't have an account?
                <a asp-action="Register" class="fw-bold text-decoration-none" style="color: #635f40;">Create one</a>
            </p>

        </div>
    </div>
</div>

<!-- Footer -->
<footer class="mt-5 py-5">
    <div class="container">
        <div class="row g-4">

            <div class="col-md-3">
                <h5 class="brand">GLOWCARE</h5>
                <p class="text-muted small">Luxury skincare experience blending science and nature.</p>
            </div>

            <div class="col-md-3">
                <h6 class="fw-bold small text-uppercase mb-3" style="letter-spacing: 1px; color: #635f40;">Shop</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-muted small">Shop All</a></li>
                    <li><a href="#" class="text-decoration-none text-muted small">Best Sellers</a></li>
                </ul>
            </div>

            <div class="col-md-3">
                <h6 class="fw-bold small text-uppercase mb-3" style="letter-spacing: 1px; color: #635f40;">Resources</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-muted small">Privacy Policy</a></li>
                    <li><a href="#" class="text-decoration-none text-muted small">Terms of Service</a></li>
                </ul>
            </div>

            <div class="col-md-3">
                <h6 class="fw-bold small text-uppercase mb-3" style="letter-spacing: 1px; color: #635f40;">Company</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-muted small">Contact Us</a></li>
                    <li><a href="#" class="text-decoration-none text-muted small">Careers</a></li>
                </ul>
            </div>

        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
